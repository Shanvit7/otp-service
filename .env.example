# ─── App ──────────────────────────────────────────────────────────────────────
# Runtime environment. Controls log level defaults and error message verbosity.
# Values: development | production | test
NODE_ENV=development

# ─── Server ───────────────────────────────────────────────────────────────────
# TCP port the Hono HTTP server binds to.
PORT=3000

# Network interface to bind. Use 0.0.0.0 to accept connections on all interfaces.
HOST=0.0.0.0

# ─── Redis ────────────────────────────────────────────────────────────────────
# Full Redis connection URL.
# Format: redis://[username:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379

# Namespace prefix applied to every Redis key (e.g. "otp" → "otp:userId:code").
# Change per environment to isolate dev / staging / prod data on a shared Redis.
REDIS_KEY_PREFIX=otp

# ─── OTP ──────────────────────────────────────────────────────────────────────
# How long (seconds) a generated OTP remains valid before expiring.
# Default: 300 (5 minutes)
OTP_TTL_SECONDS=300

# Maximum number of incorrect verify attempts before the OTP is locked.
# Default: 5
OTP_MAX_ATTEMPTS=5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum OTP generation requests allowed per userId within each window.
# Windows are rolling from the first request — not fixed clock boundaries.

# Per-minute cap (default: 3)
RATE_LIMIT_MINUTE=3

# Per-hour cap (default: 10)
RATE_LIMIT_HOUR=10

# Per-day cap (default: 20)
RATE_LIMIT_DAY=20

# ─── Logging ──────────────────────────────────────────────────────────────────
# Pino log level. Omit to use the environment-driven default:
#   development → debug
#   production  → info
# Values: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug
